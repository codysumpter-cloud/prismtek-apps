{
  "schemaVersion": 1,
  "purpose": "Integration contracts for using external game engines as research-backed adapters without vendoring third-party source, binaries, or assets into shipped Prismtek game paths.",
  "defaultPolicy": {
    "adapterRoot": "tools/integrations/",
    "docsRoot": "docs/integrations/",
    "shipPolicy": "Adapters may generate or transform Prismtek-owned project files, but must not copy external engine code, modules, binaries, art, audio, fonts, models, or data into shipped paths without explicit provenance and license review.",
    "preferredUse": "Keep external engines as local developer dependencies or documented upstream references, then ship original Prismtek code and assets."
  },
  "adapters": [
    {
      "id": "godot-engine-adapter",
      "name": "Godot Engine Adapter",
      "sourceReferenceId": "godot",
      "url": "https://github.com/godotengine/godot.git",
      "kind": "general-game-engine-adapter",
      "status": "contract-only",
      "targetPath": "experiments/godot-prismtek-spike/",
      "supportedTargets": [
        "web",
        "windows",
        "macos",
        "linux",
        "android",
        "rgds-android",
        "rgds-linux"
      ],
      "licenseObserved": "MIT per upstream project materials",
      "pluginEntryPoints": {
        "intake": "tools/integrations/godot/intake.mjs",
        "validate": "tools/integrations/godot/validate.mjs",
        "export": "tools/integrations/godot/export.mjs"
      },
      "validation": {
        "manifestRequired": true,
        "licenseReviewRequired": true,
        "artifactReceiptRequired": true,
        "forbiddenOutputs": [
          "external engine source",
          "external binaries",
          "unreviewed third-party assets"
        ]
      },
      "notes": "Use for broad 2D/3D prototype evaluation only until a concrete Prismtek-owned project adapter exists."
    },
    {
      "id": "phaser-web-adapter",
      "name": "Phaser Web Adapter",
      "sourceReferenceId": "phaser",
      "url": "https://github.com/phaserjs/phaser.git",
      "kind": "web-game-framework-adapter",
      "status": "contract-only",
      "targetPath": "games/_shared/prismtek-arcade/engines/phaser/",
      "supportedTargets": [
        "web",
        "itch-zip",
        "desktop-web-wrapper",
        "rgds-android-browser",
        "rgds-linux-browser"
      ],
      "licenseObserved": "MIT per upstream project materials",
      "pluginEntryPoints": {
        "intake": "tools/integrations/phaser/intake.mjs",
        "validate": "tools/integrations/phaser/validate.mjs",
        "export": "tools/integrations/phaser/export.mjs"
      },
      "validation": {
        "manifestRequired": true,
        "licenseReviewRequired": true,
        "artifactReceiptRequired": true,
        "forbiddenOutputs": [
          "vendored npm cache",
          "unreviewed third-party assets",
          "generated files without receipt"
        ]
      },
      "notes": "Best first target for browser-first Prismtek arcade upgrades and reusable game-loop contracts."
    },
    {
      "id": "gamemaker-html5-adapter",
      "name": "GameMaker HTML5 Adapter",
      "sourceReferenceId": "gamemaker-html5",
      "url": "https://github.com/YoYoGames/GameMaker-HTML5.git",
      "kind": "browser-game-export-adapter",
      "status": "contract-only",
      "targetPath": "experiments/gamemaker-html5-prismcade-adapter/",
      "supportedTargets": [
        "web",
        "itch-zip",
        "desktop-web-wrapper",
        "gx-games-research",
        "prismcade-import-research"
      ],
      "licenseObserved": "upstream license and runtime redistribution terms require exact review before vendoring or shipping",
      "pluginEntryPoints": {
        "intake": "tools/integrations/gamemaker-html5/intake.mjs",
        "validate": "tools/integrations/gamemaker-html5/validate.mjs",
        "export": "tools/integrations/gamemaker-html5/export.mjs"
