      "validation": {
        "manifestRequired": true,
        "licenseReviewRequired": true,
        "artifactReceiptRequired": true,
        "forbiddenOutputs": [
          "vendored GameMaker runtime source",
          "unchecked generated HTML5 exports",
          "unreviewed marketplace assets",
          "GameMaker IDE/runtime binaries"
        ]
      },
      "notes": "Research adapter for wrapping GameMaker HTML5 exports in Prismcade play pages, leaderboards, profile shells, and challenge routes without copying upstream runtime code into shipped Prismtek paths."
    },
    {
      "id": "gamemaker-cli-tooling-adapter",
