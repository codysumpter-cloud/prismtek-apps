# Prismtek Apps development environment
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://prismtek:prismtek@localhost:5432/prismtek?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI Providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Agent memory
AGENTMEMORY_URL=http://localhost:3111
AGENTMEMORY_SECRET=

# Product sandbox configuration
SANDBOX_DOCKER_IMAGE=prismtek/sandbox:latest
SANDBOX_MAX_MEMORY=512MB
SANDBOX_MAX_CPU=0.5

# App Factory
GITHUB_TOKEN=
TEMPLATES_REPO=codysumpter-cloud/prismbot-templates
