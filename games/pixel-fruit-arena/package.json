{
  "name": "@prismtek/pixel-fruit-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pixel Fruit Arena MVP - local multiplayer platform fighting prototype.",
  "scripts": {
    "build": "node tools/build.mjs",
    "test": "node tools/test.mjs",
    "catalog:assets": "node tools/build_asset_catalog.mjs",
    "validate:catalog": "node tools/validate_asset_catalog.mjs",
    "validate:assets": "python tools/validate_sprites.py assets/characters/prismtek_placeholder_character.json",
    "build:ps": "powershell -ExecutionPolicy Bypass -File tools/build.ps1",
    "test:ps": "powershell -ExecutionPolicy Bypass -File tools/test.ps1",
    "validate:assets:ps": "powershell -ExecutionPolicy Bypass -File tools/validate_sprites.ps1 assets/characters/prismtek_placeholder_character.json",
    "serve:ps": "powershell -ExecutionPolicy Bypass -File tools/serve.ps1",
    "install:reference:ps": "powershell -ExecutionPolicy Bypass -File tools/install_local_onepiece_reference_assets.ps1"
  },
  "keywords": [
    "game",
    "platform-fighter",
    "pixel-art",
    "prismtek"
  ],
  "license": "UNLICENSED"
}
