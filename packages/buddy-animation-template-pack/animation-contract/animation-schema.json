{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prismtek.dev/schemas/buddy-animation-manifest.schema.json",
  "title": "Buddy Animation Manifest",
  "type": "object",
  "required": ["schemaVersion", "variantId", "frame", "sheet", "animations", "provenance"],
  "properties": {
    "schemaVersion": {
      "const": "buddy-animation-manifest-v1"
    },
    "variantId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "frame": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "enum": [64, 128] },
        "height": { "type": "integer", "enum": [64, 128] },
        "baselineY": { "type": "integer", "minimum": 0 },
        "pivotX": { "type": "integer", "minimum": 0 },
        "pivotY": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "sheet": {
      "type": "object",
      "required": ["path", "columns", "rows"],
      "properties": {
        "path": { "type": "string" },
        "columns": { "type": "integer", "minimum": 1, "maximum": 64 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 64 },
        "transparentBackground": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "animations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "family", "fps", "loop", "frames"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "family": { "type": "string", "enum": ["idle", "movement", "emote", "melee", "rpg-attack", "status-effect", "damage", "victory-defeat"] },
          "fps": { "type": "integer", "minimum": 1, "maximum": 30 },
          "loop": { "type": "boolean" },
          "frames": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["row", "column"],
              "properties": {
                "row": { "type": "integer", "minimum": 0 },
                "column": { "type": "integer", "minimum": 0 },
                "durationMs": { "type": "integer", "minimum": 1 },
                "tag": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "hitFrames": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source", "rights", "createdBy"],
      "properties": {
        "source": { "type": "string" },
        "rights": { "type": "string" },
        "createdBy": { "type": "string" },
        "generatedWith": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
