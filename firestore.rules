rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "Cody.Sumpter@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    function isValidWorkspace(data) {
      return hasOnlyAllowedFields(['id', 'ownerId', 'name', 'templateId', 'status', 'repoUrl', 'lastSyncedAt', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.ownerId is string && data.ownerId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.templateId is string && data.templateId.size() > 0 &&
             data.status in ['running', 'paused', 'syncing', 'error'];
    }

    function isValidSandboxSession(data) {
      return hasOnlyAllowedFields(['id', 'workspaceId', 'ownerId', 'status', 'expiresAt', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.workspaceId is string && data.workspaceId.size() > 0 &&
             data.ownerId is string && data.ownerId.size() > 0 &&
             data.status in ['starting', 'running', 'terminated'];
    }

    function isValidSystemLog(data) {
      return hasOnlyAllowedFields(['id', 'event', 'user', 'time', 'type']) &&
             data.id is string && data.id.size() > 0 &&
             data.event is string && data.event.size() > 0 && data.event.size() < 500 &&
             data.type in ['info', 'success', 'warning', 'error'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && uidNotModified();
    }

    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWorkspace(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidWorkspace(request.resource.data) && (resource.data.ownerId == request.auth.uid || isAdmin()) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sandbox_sessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSandboxSession(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidSandboxSession(request.resource.data) && (resource.data.ownerId == request.auth.uid || isAdmin()) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidSystemLog(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
