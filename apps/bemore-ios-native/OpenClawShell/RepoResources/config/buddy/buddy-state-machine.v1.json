{"$schema":"https://json-schema.org/draft/2020-12/schema","version":"1.0.0","id":"buddy-state-machine-v1","description":"Canonical Buddy runtime state machine for instance lifecycle, progression, mood/activity, install flow, and publish/sanitation flow.","domains":{"lifecycle":{"initial":"draft","states":{"draft":{"description":"Buddy has been created but not yet activated.","allowedTransitions":["onboarded","archived"]},"onboarded":{"description":"Buddy is visible to the user and eligible for check-ins, training, and tasks.","allowedTransitions":["active","archived"]},"active":{"description":"Default live state for an installed Buddy.","allowedTransitions":["idle","training","onTask","inChallenge","publishingDraft","archived"]},"idle":{"description":"Buddy is active but not currently training or assigned work.","allowedTransitions":["active","training","onTask","sleeping","archived"]},"training":{"description":"Buddy is in a structured training loop.","allowedTransitions":["active","idle","inChallenge","archived"]},"onTask":{"description":"Buddy is executing or assisting with a real task.","allowedTransitions":["active","idle","stale","archived"]},"inChallenge":{"description":"Buddy is participating in a daily or weekly trial.","allowedTransitions":["active","idle","archived"]},"sleeping":{"description":"Low-energy recovery state.","allowedTransitions":["idle","active","archived"]},"stale":{"description":"Buddy needs attention because activity, memory review, or routines have lapsed.","allowedTransitions":["active","idle","archived"]},"publishingDraft":{"description":"A packaging flow is in progress for sanitized template export.","allowedTransitions":["active","packaged","archived"]},"packaged":{"description":"A sanitized template draft exists for this Buddy.","allowedTransitions":["active","published","archived"]},"published":{"description":"A publishable or published template exists; live Buddy remains separate.","allowedTransitions":["active","archived"]},"arch