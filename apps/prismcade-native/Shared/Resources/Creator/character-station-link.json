{
  "schemaVersion": "prismcade-native-creator-tool-link-v0",
  "id": "character-creation-station",
  "title": "Character Creation Station",
  "description": "Bundled in-app outfit-safe 64x64 avatar recipe and Prismcade manifest exporter.",
  "bundledAppResource": {
    "path": "Shared/Resources/Creator/character-station.html",
    "opensWith": "CharacterStationView",
    "requiresLocalhost": false,
    "offlineReady": true
  },
  "dataContracts": {
    "sourcePacks": "data/prismcade/character-creator-packs.json",
    "sampleRecipe": "data/prismcade/character-recipes/starter-avatar.recipe.json",
    "sampleManifest": "data/prismcade/character-manifests/starter-avatar.manifest.json",
    "pixelFruitArenaAdapter": "games/pixel-fruit-arena/src/characters/prismcadeCreatorAdapter.js"
  },
  "nativeIntegration": "Shown as a Creator Tools card in the SwiftUI Prismcade hub; the card opens a bundled WKWebView sheet and no longer requires localhost."
}
