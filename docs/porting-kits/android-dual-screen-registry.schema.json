{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prismtek.dev/schemas/android-dual-screen-registry.schema.json",
  "title": "Prismtek Android dual-screen game registry",
  "type": "object",
  "required": ["games"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "games": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gameId", "config", "defaultDisplayMode"],
        "additionalProperties": false,
        "properties": {
          "gameId": { "type": "string", "minLength": 1 },
          "config": { "type": "string", "minLength": 1 },
          "defaultDisplayMode": {
            "enum": ["single", "stacked-ds", "foldable-ds", "external-display", "rgds-dual"]
          }
        }
      }
    }
  }
}
